<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- REQUIRED: without a CFBundleIdentifier, GCController.controllers() is
       permanently empty (the framework caches the pad list keyed by bundle id
       at launch). This plist is embedded into the binary via the linker's
       -sectcreate __TEXT __info_plist — see build-mac.sh. -->
  <key>CFBundleIdentifier</key>
  <string>com.wltoys.gamepad</string>
  <key>CFBundleName</key>
  <string>wltoys-gamepad</string>
  <key>CFBundleVersion</key>
  <string>1.0</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0</string>
</dict>
</plist>
